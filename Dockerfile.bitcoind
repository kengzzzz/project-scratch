FROM debian:trixie-slim@sha256:1d3c811171a08a5adaa4a163fbafd96b61b87aa871bbc7aa15431ac275d3d430 AS verifier

ARG VERSION SOURCE_SHA256 MIN_TRUSTED_SIGNERS=5

RUN apt-get update && apt-get install -y --no-install-recommends curl gnupg ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /verify

RUN set -ex; \
    V=${VERSION#v}; \
    [ -n "$SOURCE_SHA256" ]; \
    URL="https://bitcoincore.org/bin/bitcoin-core-$V"; \
    curl -sLO "$URL/bitcoin-$V.tar.gz"; \
    curl -sLO "$URL/SHA256SUMS.asc"; \
    curl -sLO "$URL/SHA256SUMS"; \
    curl -sL https://github.com/bitcoin-core/guix.sigs/archive/refs/heads/main.tar.gz | tar -xz --strip-components=1 guix.sigs-main/builder-keys; \
    gpg --import builder-keys/*.gpg 2>/dev/null || true; \
    VALID_SIGS=$(gpg --status-fd 1 --verify SHA256SUMS.asc SHA256SUMS 2>/dev/null | grep -c "^\[GNUPG:\] VALIDSIG"); \
    [ "$VALID_SIGS" -ge "$MIN_TRUSTED_SIGNERS" ]; \
    grep -q "$SOURCE_SHA256" SHA256SUMS; \
    echo "$SOURCE_SHA256  bitcoin-$V.tar.gz" | sha256sum -c -; \
    mkdir -p /verified-src; \
    tar -xzf "bitcoin-$V.tar.gz" -C /verified-src --strip-components=1

FROM alpine@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659 AS builder

RUN apk add --no-cache build-base libtool autoconf automake pkgconf curl python3 cmake ninja bash patch linux-headers ca-certificates

WORKDIR /src

COPY --from=verifier /verified-src/ /src/

RUN export HOST=$(uname -m)-linux-musl && make -C depends HOST=$HOST NO_QT=1 NO_ZMQ=1 NO_WALLET=1 NO_USDT=1 NO_IPC=1 -j$(nproc)

RUN export HOST=$(uname -m)-linux-musl && cmake -B build -G Ninja --toolchain /src/depends/$HOST/toolchain.cmake \
    -DAPPEND_CFLAGS="-ffunction-sections -fdata-sections -march=native" \
    -DAPPEND_CXXFLAGS="-ffunction-sections -fdata-sections -march=native" \
    -DAPPEND_LDFLAGS="-static -Wl,--gc-sections" \
    -DBUILD_BENCH=OFF \
    -DBUILD_BITCOIN_BIN=OFF \
    -DBUILD_CLI=ON \
    -DBUILD_DAEMON=ON \
    -DBUILD_GUI=OFF \
    -DBUILD_KERNEL_LIB=OFF \
    -DBUILD_TESTS=OFF \
    -DBUILD_TX=OFF \
    -DBUILD_UTIL=OFF \
    -DBUILD_UTIL_CHAINSTATE=OFF \
    -DCMAKE_BUILD_TYPE=Release \
    -DENABLE_EXTERNAL_SIGNER=OFF \
    -DENABLE_IPC=OFF \
    -DENABLE_WALLET=OFF \
    -DINSTALL_MAN=OFF \
    -DREDUCE_EXPORTS=ON \
    -DWERROR=OFF \
    -DWITH_CCACHE=OFF \
    -DWITH_USDT=OFF \
    -DWITH_ZMQ=OFF

RUN cmake --build build --parallel $(nproc)

RUN mkdir -p /rootfs/etc/ssl/certs /rootfs/usr/bin /rootfs-writable/data /rootfs-writable/tmp && \
    echo "bitcoind:x:1000:1000:bitcoind:/data:/sbin/nologin" > /rootfs/etc/passwd && echo "bitcoind:x:1000:" > /rootfs/etc/group && \
    strip -s build/bin/bitcoind build/bin/bitcoin-cli && \
    cp /etc/ssl/certs/ca-certificates.crt /rootfs/etc/ssl/certs/ && cp build/bin/bitcoind build/bin/bitcoin-cli /rootfs/usr/bin/ && \
    chmod 1777 /rootfs-writable/tmp

FROM scratch AS exporter

COPY --from=builder /rootfs/ /

COPY --from=builder --chown=1000:1000 /rootfs-writable/ /

FROM scratch

COPY --from=exporter / /

USER 1000:1000

WORKDIR /data

ENV BITCOIN_DATA=/data

HEALTHCHECK --interval=60s --timeout=5s --start-period=15s --retries=3 CMD ["/usr/bin/bitcoin-cli", "-datadir=/data", "getblockchaininfo"]

ENTRYPOINT ["/usr/bin/bitcoind"]
CMD ["-datadir=/data", "-conf=/data/bitcoin.conf", "-printtoconsole"]