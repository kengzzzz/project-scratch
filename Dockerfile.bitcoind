FROM alpine@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659 AS builder

ARG VERSION COMMIT_HASH

RUN apk add --no-cache build-base libtool autoconf automake pkgconf curl git python3 cmake ninja bash patch linux-headers coreutils ca-certificates

WORKDIR /src
RUN git clone --depth 1 --branch ${VERSION} https://github.com/bitcoin/bitcoin.git . && \
    [ -n "$COMMIT_HASH" ] && [ "$(git rev-parse HEAD)" = "$COMMIT_HASH" ] || { echo "Hash mismatch"; exit 1; }

RUN export HOST=$(uname -m)-linux-musl && \
    make -C depends HOST=$HOST CC=gcc CXX=g++ AR=ar RANLIB=ranlib STRIP=strip NO_QT=1 NO_UPNP=1 NO_NATPMP=1 NO_ZMQ=1 NO_WALLET=1 -j$(nproc) && \
    cmake -B build -G Ninja --toolchain /src/depends/$HOST/toolchain.cmake \
    -DAPPEND_CFLAGS="-ffunction-sections -fdata-sections -march=native" \
    -DAPPEND_CXXFLAGS="-ffunction-sections -fdata-sections -march=native" \
    -DAPPEND_LDFLAGS="-static -Wl,--gc-sections" \
    -DBUILD_BENCH=OFF \
    -DBUILD_BITCOIN_BIN=OFF \
    -DBUILD_CLI=ON \
    -DBUILD_DAEMON=ON \
    -DBUILD_GUI=OFF \
    -DBUILD_KERNEL_LIB=OFF \
    -DBUILD_TESTS=OFF \
    -DBUILD_TX=OFF \
    -DBUILD_UTIL=OFF \
    -DBUILD_UTIL_CHAINSTATE=OFF \
    -DCMAKE_BUILD_TYPE=Release \
    -DENABLE_EXTERNAL_SIGNER=OFF \
    -DENABLE_IPC=OFF \
    -DENABLE_WALLET=OFF \
    -DINSTALL_MAN=OFF \
    -DREDUCE_EXPORTS=ON \
    -DWERROR=OFF \
    -DWITH_CCACHE=OFF \
    -DWITH_USDT=OFF \
    -DWITH_ZMQ=OFF && \
    cmake --build build --parallel $(nproc) && \
    mkdir -p /src/output && \
    cp build/bin/bitcoind build/bin/bitcoin-cli /src/output/

RUN mkdir -p /rootfs/etc/ssl/certs /rootfs/usr/bin /rootfs-writable/data /rootfs-writable/tmp && \
    echo "bitcoind:x:1000:1000:bitcoind:/data:/sbin/nologin" > /rootfs/etc/passwd && echo "bitcoind:x:1000:" > /rootfs/etc/group && \
    strip -s /src/output/bitcoind /src/output/bitcoin-cli && \
    cp /etc/ssl/certs/ca-certificates.crt /rootfs/etc/ssl/certs/ && cp /src/output/bitcoind /src/output/bitcoin-cli /rootfs/usr/bin/ && \
    chmod 1777 /rootfs-writable/tmp

FROM scratch

COPY --from=builder /rootfs/ /

COPY --from=builder --chown=1000:1000 /rootfs-writable/ /

USER 1000:1000

WORKDIR /data

ENV BITCOIN_DATA=/data

HEALTHCHECK --interval=60s --timeout=5s --start-period=15s --retries=3 CMD ["/usr/bin/bitcoin-cli", "-datadir=/data", "getblockchaininfo"]

ENTRYPOINT ["/usr/bin/bitcoind"]
CMD ["-datadir=/data", "-conf=/data/bitcoin.conf", "-printtoconsole"]