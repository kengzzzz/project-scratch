FROM rust:alpine@sha256:ef7b340d4201444fa2757dfddfd4c03be9d2bde468de7b7a68b0e9fabb794334 AS builder

ARG VW_VERSION WV_VERSION COMMIT_HASH
ENV OPENSSL_STATIC=1 RUSTFLAGS="-C target-feature=+crt-static -C target-cpu=native" CARGO_PROFILE_RELEASE_OPT_LEVEL="3" CARGO_PROFILE_RELEASE_CODEGEN_UNITS="1" CARGO_PROFILE_RELEASE_LTO="fat" CARGO_PROFILE_RELEASE_PANIC="abort" CARGO_PROFILE_RELEASE_STRIP="true"

RUN apk add --no-cache build-base git curl pkgconfig openssl-dev openssl-libs-static sqlite-dev sqlite-static ca-certificates tzdata

WORKDIR /app
RUN mkdir -p web-vault && \
    curl -L "https://github.com/dani-garcia/bw_web_builds/releases/download/${WV_VERSION}/bw_web_${WV_VERSION}.tar.gz" | tar xz -C web-vault --strip-components=1 && \
    find web-vault -name "*.map" -type f -delete && find web-vault -name "*.txt" -type f -delete && rm -rf web-vault/videos && \
    if [ -d "web-vault/locales" ]; then find web-vault/locales -maxdepth 1 -type d ! -name "locales" ! -name "en" -exec rm -rf {} +; fi

RUN find /app/web-vault -type d -exec chmod 755 {} + && find /app/web-vault -type f -exec chmod 644 {} +

WORKDIR /src
RUN git clone --depth 1 --branch ${VW_VERSION} https://github.com/dani-garcia/vaultwarden.git . && \
    [ -n "$COMMIT_HASH" ] && [ "$(git rev-parse HEAD)" = "$COMMIT_HASH" ] || { echo "Hash mismatch"; exit 1; }

RUN export TARGET=$(rustc -vV | sed -n 's/host: //p') && \
    cargo build --features "sqlite,enable_mimalloc" --release --locked --target "$TARGET" && \
    cp "target/$TARGET/release/vaultwarden" target/release/vaultwarden

RUN cat <<'EOF' > healthcheck.c
#include <sys/socket.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <stdlib.h>

int main() {
    char *port_env = getenv("ROCKET_PORT");
    int port = port_env ? atoi(port_env) : 80;
    int s = socket(AF_INET, SOCK_STREAM, 0);
    if (s < 0) return 1;
    struct sockaddr_in a = {0};
    a.sin_family = AF_INET;
    a.sin_port = htons(port);
    a.sin_addr.s_addr = inet_addr("127.0.0.1");

    int r = connect(s, (struct sockaddr *)&a, sizeof(a));
    close(s);
    return (r == 0) ? 0 : 1;
}
EOF

RUN gcc -static -Os -s -fno-stack-protector -fno-asynchronous-unwind-tables -fno-ident -o healthcheck healthcheck.c

RUN mkdir -p /rootfs/etc/ssl/certs /rootfs/usr/bin /rootfs/usr/share/zoneinfo/Asia /rootfs-writable/data /rootfs-writable/tmp /rootfs-writable/web-vault && \
    echo "vaultwarden:x:1000:1000:vaultwarden:/var/empty:/sbin/nologin" > /rootfs/etc/passwd && echo "vaultwarden:x:1000:" > /rootfs/etc/group && \
    cp /etc/ssl/certs/ca-certificates.crt /rootfs/etc/ssl/certs/ && cp target/release/vaultwarden /rootfs/usr/bin/ && \
    cp healthcheck /rootfs/usr/bin/ && cp /usr/share/zoneinfo/Asia/Bangkok /rootfs/usr/share/zoneinfo/Asia/Bangkok && \
    cp -r /app/web-vault/* /rootfs-writable/web-vault/ && chmod 1777 /rootfs-writable/tmp

FROM scratch

COPY --from=builder /rootfs/ /

COPY --from=builder --chown=1000:1000 /rootfs-writable/ /

USER 1000:1000

WORKDIR /data

ENV WEB_VAULT_FOLDER=/web-vault TZ=Asia/Bangkok

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD ["/usr/bin/healthcheck"]

ENTRYPOINT ["/usr/bin/vaultwarden"]