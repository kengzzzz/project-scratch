FROM alpine@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659 AS builder

ARG VERSION COMMIT_HASH

RUN apk add --no-cache git make gcc g++ linux-headers musl-dev tzdata

WORKDIR /build

RUN git clone --depth 1 --branch ${VERSION} https://github.com/redis/redis.git . && \
    [ -n "$COMMIT_HASH" ] && [ "$(git rev-parse HEAD)" = "$COMMIT_HASH" ] || { echo "Hash mismatch"; exit 1; }

RUN make -j "$(nproc)" BUILD_TLS=no CFLAGS="-ffunction-sections -fdata-sections -march=native" LDFLAGS="-static -Wl,--gc-sections"

RUN mkdir -p /rootfs/etc /rootfs/bin /rootfs/usr/share/zoneinfo/Asia /data && \
    echo "redis:x:1000:1000:redis:/nonexistent:/sbin/nologin" > /rootfs/etc/passwd && echo "redis:x:1000:" > /rootfs/etc/group && \
    strip -s /build/src/redis-server /build/src/redis-cli && \
    cp /build/src/redis-server /rootfs/bin/ && cp /build/src/redis-cli /rootfs/bin/ && cp /build/redis.conf /rootfs/etc/ && cp /usr/share/zoneinfo/Asia/Bangkok /rootfs/usr/share/zoneinfo/Asia/Bangkok

RUN sed -i 's/^bind.*/bind 0.0.0.0/' /rootfs/etc/redis.conf && \
    sed -i 's/^protected-mode yes/protected-mode no/' /rootfs/etc/redis.conf && \
    sed -i 's/^dir .*/dir \/data/' /rootfs/etc/redis.conf

FROM scratch

COPY --from=builder /rootfs /

COPY --from=builder --chown=1000:1000 /data /data

USER 1000:1000

WORKDIR /data

ENV TZ=Asia/Bangkok

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD ["/bin/redis-cli", "ping"]

ENTRYPOINT ["/bin/redis-server"]
CMD ["/etc/redis.conf"]